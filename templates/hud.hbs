<div class="hud-root {{#if collapsed}}is-collapsed{{/if}} {{#if shiftMode}}shift-mode{{/if}}">
  <div class="bar {{#if collapsed}}collapsed{{/if}}" data-bar>
    <div class="sweep"></div>
    <div class="main">

      <div class="cell grip" title="{{localize 'GLCT.hud.dragHint'}}">
        <i></i><i></i><i></i>
      </div>

      <div class="cell pill" title="{{localize 'GLCT.hud.toggleHint'}}">
        <span class="pring" data-ring></span>
        <span class="ptxt">
          <span class="pw" data-watch></span>
          <span class="pc reelclock" data-reelclock></span>
          <span class="pd" data-pilldate></span>
        </span>
      </div>

      <div class="cell date">
        <span class="wd" data-wd></span>
        <span class="m"><span data-dy></span><sup data-ord></sup> <span data-moshort></span></span>
        <span class="mo" data-mo></span>
      </div>

      <div class="cell watch">
        <span class="name" data-watch></span>
        <span class="row">
          <span class="shifts" data-shifts></span>
          <span class="moon"><span class="shadow" data-moon></span></span>
          <span class="season" data-season></span>
        </span>
      </div>

      <div class="cell shift-hero" data-shifthero>
        <span class="sdial" data-dial></span>
        <span class="sinfo">
          <span class="name" data-watch></span>
          <span class="row">
            <span class="of" data-shiftof></span>
            <span class="moon"><span class="shadow" data-moon></span></span>
            <span class="season" data-season></span>
          </span>
          {{#if isGM}}
          <span class="minitime" title="{{localize 'GLCT.hud.gmTimeHint'}}">
            <span class="mt-clock" data-mtclock></span>
            <span class="mt-bar"><i data-mtfill></i></span>
            <span class="mt-rem" data-mtrem></span>
          </span>
          {{/if}}
        </span>
      </div>

      <div class="cell clock-cell">
        <span class="lbl">{{localize 'GLCT.hud.timeLabel'}}</span>
        <span class="clock"><span class="pulse"></span><span class="reelclock" data-reelclock></span></span>
      </div>

      <div class="cell meter">
        <div class="track" data-track></div>
        <span class="rem"><span data-rem></span></span>
        <span class="missline" data-missline>
          <span class="mc-ico"><i class="fa-solid fa-bullseye"></i></span>
          <span class="mc-reelwrap"><span class="mc-reel" data-missreel></span><span class="mc-unit" data-missunit></span></span>
          <span class="mc-chip" data-misschip><i class="fa-solid fa-flag-checkered"></i> <span data-misslabel></span></span>
        </span>
      </div>

      <div class="cell event-cell" data-action="openCalendar">
        <span class="lbl">{{localize 'GLCT.calendarView.title'}}</span>
        <span class="event" data-event><span class="dot"></span><span data-eventtxt></span></span>
      </div>

    </div>
  </div>

  {{#if isGM}}
  <div class="gmwrap" data-gmwrap>
    <div class="gmdock">
      <span class="c" data-step="stretch" data-action="advance">{{localize 'GLCT.controls.advanceStretch'}}</span>
      <span class="c" data-step="hour"    data-action="advance">{{localize 'GLCT.controls.advanceHour'}}</span>
      <span class="c" data-step="shift"   data-action="advance">{{localize 'GLCT.controls.advanceShift'}}</span>
      <span class="c" data-step="day"     data-action="advance">{{localize 'GLCT.controls.advanceDay'}}</span>
      <span class="c sep" data-action="nextShift"><i class="fa-solid fa-forward-step"></i> {{localize 'GLCT.shifts.0'}}</span>
      <span class="c sep ico" data-action="setTime" title="{{localize 'GLCT.controls.setTime'}}"><i class="fa-solid fa-stopwatch"></i></span>
      <span class="c sep mission" data-action="openMission" data-missionbtn title="{{localize 'GLCT.controls.missionToggle'}}"><i class="fa-solid fa-bullseye"></i> {{localize 'GLCT.controls.mission'}}<b class="cnt" data-missioncount></b></span>
      <span class="c sep mode" data-action="toggleShiftMode" data-modebtn title="{{localize 'GLCT.controls.shiftModeToggle'}}"><i class="fa-solid fa-circle-half-stroke"></i> <span data-modetext></span></span>
    </div>
  </div>
  {{/if}}
</div>
